#!/bin/bash
set -euo pipefail

# x-transcribe: legacy wrapper for X post transcription.
# X support (download + full frames + transcript) is now merged into ./video-understanding.sh
# Usage for X:
#   ./video-understanding.sh <x-url-or-id> [--video <direct-mp4-url>] [--name <slug>]
#
# This script kept for compatibility with x/ output format.
# It still supports the old usage for chunked md transcript.
# For new use, prefer the main script which handles X + frames + understanding.

XREF=${1:-}
VIDEO_URL=""
SLUG=""

while [[ $# -gt 0 ]]; do
  case $1 in
    --video) VIDEO_URL="$2"; shift 2 ;;
    --name)  SLUG="$2"; shift 2 ;;
    *)       XREF="$1"; shift ;;
  esac
done

if [[ -z "$XREF" ]]; then
  echo "Usage: x/bin/x-transcribe <https://x.com/.../status/ID | ID> [--video <mp4-url>] [--name <slug>]" >&2
  exit 1
fi

# Extract post ID
POST_ID=$(echo "$XREF" | sed -n 's/.*status\/\([0-9]*\).*/\1/p; s/^\([0-9]*\)$/\1/p' | head -1)
if [[ -z "$POST_ID" ]]; then
  echo "Could not parse post ID from: $XREF" >&2
  exit 1
fi

if [[ -z "$SLUG" ]]; then
  SLUG="x-post-${POST_ID}"
fi

MEDIA_DIR="x/media"
TRANSCRIPT_DIR="x/library/interviews/x-posts"
mkdir -p "$MEDIA_DIR" "$TRANSCRIPT_DIR" /tmp/x-chunks

VIDEO_FILE="${MEDIA_DIR}/${SLUG}.mp4"
AUDIO_FILE="/tmp/${SLUG}-audio.m4a"
CHUNK_DIR="/tmp/x-chunks/${SLUG}"
TRANSCRIPT_FILE="${TRANSCRIPT_DIR}/${SLUG}.transcript.md"

echo "==> X post: $XREF (ID: $POST_ID)"
echo "==> Slug: $SLUG"

if [[ -n "$VIDEO_URL" && ! -f "$VIDEO_FILE" ]]; then
  echo "==> Downloading video..."
  curl -L --progress-bar -o "$VIDEO_FILE" "$VIDEO_URL"
fi

if [[ ! -f "$VIDEO_FILE" ]]; then
  echo "No video at $VIDEO_FILE. Provide --video <direct twimg mp4 url> or place file first." >&2
  exit 1
fi

echo "==> Using unified video-understanding CLI for full pipeline (frames + transcript + agent)"
./video-understanding.sh "$VIDEO_FILE" 5 "${SLUG}_understand"

echo "==> Also producing legacy chunked md for compatibility (if needed)"
# (optional: run the old chunk logic here or remove this block)
# For now, the main CLI does the heavy lifting. See README for unified use.

echo "==> Done."
echo "Video:     $VIDEO_FILE"
echo "Full output: ${SLUG}_understand/"
echo ""
echo "For pure X md transcript, the legacy chunk logic can be restored if needed." 
